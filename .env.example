# --- LangSmith (required for Modules 2 and 3, recommended for all) ---
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_PROJECT="deep-agents-interrupt-resume"

# --- Model provider (pick ONE — uncomment the provider you want to use) ---

# OpenAI
OPENAI_API_KEY="<openai-api-key>"

# Anthropic
# ANTHROPIC_API_KEY="<anthropic-api-key>"

# Azure OpenAI
# AZURE_OPENAI_API_KEY="<azure-openai-api-key>"
# AZURE_OPENAI_ENDPOINT="<azure-openai-endpoint>"
# AZURE_OPENAI_API_VERSION=""

# AWS Bedrock
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION_NAME=""
# AWS_MODEL_ARN=""

# --- Web search (used by Modules 2 and 3) ---
TAVILY_API_KEY="<tavily-api-key>"
